# Firebase Service Account (JSON from Firebase Console)
# Get from: Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"data-dogs-mission-control",...}

# SAM.gov API Key
# Get from: https://sam.gov/profile/api-key
SAM_GOV_API_KEY=your_sam_gov_api_key

# Brave Search API Key (for web scraping)
# Get from: https://brave.com/search-api/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# Cron Secret (optional - for securing cron endpoints)
CRON_SECRET=your_cron_secret_here
